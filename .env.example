# Application Environment (dev, prod)
YII_ENV=dev
YII_DEBUG=true

# Database Configuration
DB_HOST=db
DB_NAME=dilg_pmis
DB_USER=root
DB_PASSWORD=root
DB_PORT=3306

# JWT Configuration
JWT_SECRET=replace-me-with-a-random-string
JWT_EXPIRE=3600

# Vite Dev Server (for Hot Module Replacement)
# Use 'localhost' for your browser, 'node' for internal Docker communication
VITE_DEV_SERVER_URL=http://localhost:5173
VITE_DEV_SERVER_INTERNAL_URL=http://node:5173
VITE_DEV_SERVER_FORCE=false

# Ports for Docker
WEB_PORT=9001
VITE_PORT=5173
DB_PORT_EXTERNAL=3307
